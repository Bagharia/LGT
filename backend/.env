# Port du serveur
PORT=5000

# URL de connexion PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:PEP-corn1006@localhost:8000/tshirt_custom"

# Secret pour JWT (change cette valeur par quelque chose de complexe en production)
JWT_SECRET=ton_secret_jwt_super_securise_change_moi

# Clés Stripe (obtiens-les sur https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Configuration Cloudinary pour upload d'images (obtiens-les sur https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS Origin (frontend URL)
FRONTEND_URL=http://localhost:5173